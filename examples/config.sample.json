{
  "host_id": "jc-server",
  "storage": {
    "base_dir": "/var/lib/watchclaw"
  },
  "collection": {
    "listeners": {
      "enabled": true,
      "command": ["ss", "-ltnup"]
    },
    "files": {
      "paths": [
        "/etc/ssh/sshd_config",
        "/etc/ssh/sshd_config.d/*.conf",
        "/etc/passwd",
        "/etc/group",
        "/etc/shadow",
        "/etc/gshadow",
        "/etc/sudoers",
        "/etc/sudoers.d/*",
        "/etc/crontab",
        "/etc/cron.d/*",
        "/root/.ssh/authorized_keys",
        "/home/*/.ssh/authorized_keys"
      ]
    },
    "auth": {
      "enabled": true,
      "journal_command": ["journalctl", "-q", "-o", "json", "--no-pager"],
      "log_paths": ["/var/log/auth.log", "/var/log/secure"]
    }
  },
  "runtime": {
    "mode": "timer",
    "delivery": {
      "telegram_inline": true
    }
  }
}
